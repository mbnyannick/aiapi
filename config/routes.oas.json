{
  "openapi": "3.1.0",
  "info": {
    "title": "AI Data Gateway API",
    "version": "1.0.0",
    "description": "Pay-per-request API providing real-time and compliance-focused data on logistics, real estate, healthcare, and finance sectors.",
    "contact": {
      "name": "API Support",
      "email": "support@aidata.com"
    }
  },
  "servers": [
    {
      "url": "https://aiapi-main-b378d28.zuplo.app",
      "description": "Production Gateway"
    },
    {
      "url": "https://aiapi-main-5791536.d2.zuplo.dev",
      "description": "Working Copy (Dev)"
    }
  ],
  "tags": [
    { "name": "Logistics",   "description": "Border wait times, port codes, lane status, freight compliance" },
    { "name": "Healthcare",  "description": "ICD-10 codes, CPT codes, HIPAA compliance, billing rules" },
    { "name": "Real Estate", "description": "Zoning codes, building permits, tax credits, compliance rules" },
    { "name": "Finance",     "description": "SEC filings, ESG metrics, ISO controls, audit data" },
    { "name": "Discovery",   "description": "AI agent discovery and health check" }
  ],
  "paths": {

    "/mcp/logistics": {
      "get": {
        "tags": ["Logistics"],
        "summary": "List all logistics niches",
        "operationId": "listLogistics",
        "parameters": [
          { "name": "limit",  "in": "query", "schema": { "type": "integer", "default": 50,  "maximum": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": { "description": "List of logistics niche IDs" }
        },
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": { "baseUrl": "https://ai-data-vault.onrender.com" }
          },
          "policies": { "inbound": ["monetization-inbound"] }
        }
      }
    },

    "/mcp/healthcare": {
      "get": {
        "tags": ["Healthcare"],
        "summary": "List all healthcare niches",
        "operationId": "listHealthcare",
        "parameters": [
          { "name": "limit",  "in": "query", "schema": { "type": "integer", "default": 50, "maximum": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": { "description": "List of healthcare niche IDs" }
        },
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": { "baseUrl": "https://ai-data-vault.onrender.com" }
          },
          "policies": { "inbound": ["monetization-inbound"] }
        }
      }
    },

    "/mcp/realestate": {
      "get": {
        "tags": ["Real Estate"],
        "summary": "List all real estate niches",
        "operationId": "listRealEstate",
        "parameters": [
          { "name": "limit",  "in": "query", "schema": { "type": "integer", "default": 50, "maximum": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": { "description": "List of real estate niche IDs" }
        },
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": { "baseUrl": "https://ai-data-vault.onrender.com" }
          },
          "policies": { "inbound": ["monetization-inbound"] }
        }
      }
    },

    "/mcp/finance": {
      "get": {
        "tags": ["Finance"],
        "summary": "List all finance niches",
        "operationId": "listFinance",
        "parameters": [
          { "name": "limit",  "in": "query", "schema": { "type": "integer", "default": 50, "maximum": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": { "description": "List of finance niche IDs" }
        },
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": { "baseUrl": "https://ai-data-vault.onrender.com" }
          },
          "policies": { "inbound": ["monetization-inbound"] }
        }
      }
    },

    "/mcp/{niche_id}": {
      "get": {
        "tags": ["Logistics"],
        "summary": "Get niche data by ID",
        "operationId": "getNicheById",
        "description": "Returns full telemetry and compliance data for a given niche ID. Example: logistics-niche-1, healthcare-niche-1.",
        "parameters": [
          {
            "name": "niche_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The niche ID (e.g. logistics-niche-1)"
          }
        ],
        "responses": {
          "200": {
            "description": "Niche data found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status":         { "type": "string",  "example": "SUCCESS" },
                    "category":       { "type": "string",  "example": "logistics" },
                    "niche":          { "type": "string",  "example": "Automated AI Compliance Dataset Matrix: LOGISTICS Protocol Code 1" },
                    "telemetry_data": { "type": "object" },
                    "mcp_context":    { "type": "object" }
                  }
                }
              }
            }
          },
          "404": { "description": "Niche ID not found" },
          "500": { "description": "Database error" }
        },
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": { "baseUrl": "https://ai-data-vault.onrender.com" }
          },
          "policies": { "inbound": ["monetization-inbound"] }
        }
      }
    },

    "/llms.txt": {
      "get": {
        "tags": ["Discovery"],
        "summary": "AI agent discovery file",
        "operationId": "getLlmsTxt",
        "description": "Returns a plain text discovery file for AI agents and LLMs.",
        "responses": {
          "200": { "description": "Discovery file returned" }
        },
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": { "baseUrl": "https://ai-data-vault.onrender.com" }
          },
          "policies": { "inbound": [] }
        }
      }
    },

    "/health": {
      "get": {
        "tags": ["Discovery"],
        "summary": "Health check",
        "operationId": "healthCheck",
        "description": "Returns ok status. Use for uptime monitoring.",
        "responses": {
          "200": { "description": "Service is healthy" }
        },
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": { "baseUrl": "https://ai-data-vault.onrender.com" }
          },
          "policies": { "inbound": [] }
        }
      }
    }

  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Authorization: Bearer YOUR_API_KEY"
      }
    }
  },
  "security": [
    { "ApiKeyAuth": [] }
  ]
}