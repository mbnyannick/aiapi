{
  "openapi": "3.1.0",
  "info": {
    "title": "AI Data Gateway API",
    "version": "1.0.0",
    "description": "Pay-per-request API providing real-time and compliance-focused data on logistics, real estate, healthcare, and finance sectors.",
    "contact": {
      "name": "API Support",
      "email": "support@aidata.com"
    }
  },
  "servers": [
    {
      "url": "https://aiapi-main-b378d28.zuplo.app",
      "description": "Production Gateway"
    },
    {
      "url": "https://aiapi-main-5791536.d2.zuplo.dev",
      "description": "Working Copy (Dev)"
    }
  ],
  "tags": [
    { "name": "Data", "description": "Dynamic niche data lookup" },
    { "name": "Discovery", "description": "AI agent discovery" }
  ],
  "paths": {
    "/mcp/{niche_id}": {
      "get": {
        "tags": ["Data"],
        "summary": "Get niche data by ID",
        "operationId": "getNicheById",
        "description": "Returns telemetry and compliance data for a given niche ID. Example IDs: 450 (logistics), 1 (real estate).",
        "parameters": [
          {
            "name": "niche_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The numeric niche ID (e.g. 450)"
          }
        ],
        "responses": {
          "200": {
            "description": "Niche data found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status":         { "type": "string", "example": "SUCCESS" },
                    "niche":          { "type": "string", "example": "logistics" },
                    "telemetry_data": { "type": "object" },
                    "mcp_context":    { "type": "object" }
                  }
                }
              }
            }
          },
          "404": { "description": "Niche ID not found" },
          "500": { "description": "Database error" }
        },
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://ai-data-vault.onrender.com"
            }
          },
          "policies": { "inbound": ["monetization-inbound"] }
        }
      }
    },
    "/llms.txt": {
      "get": {
        "tags": ["Discovery"],
        "summary": "AI agent discovery file",
        "operationId": "getLlmsTxt",
        "description": "Returns a plain text discovery file for AI agents and LLMs to understand this API.",
        "responses": {
          "200": { "description": "Discovery file returned" }
        },
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://ai-data-vault.onrender.com"
            }
          },
          "policies": { "inbound": [] }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Authorization: Bearer YOUR_API_KEY"
      }
    }
  },
  "security": [
    { "ApiKeyAuth": [] }
  ]
}